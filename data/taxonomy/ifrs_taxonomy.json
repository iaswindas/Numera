  "RATIOS": {
    "Current Ratio": {
      "synonyms": ["Liquidity Ratio", "Working Capital Ratio"],
      "formula": "Total Current Assets / Total Current Liabilities"
    },
    "Quick Ratio": {
      "synonyms": ["Acid Test Ratio"],
      "formula": "(Total Current Assets - Inventories) / Total Current Liabilities"
    },
    "Debt to Equity": {
      "synonyms": ["D/E Ratio", "Leverage Ratio", "Gearing Ratio", "Debt/Equity"],
      "formula": "Total Liabilities / Total Equity"
    },
    "Debt to EBITDA": {
      "synonyms": ["Net Debt/EBITDA", "Leverage Multiple"],
      "formula": "(Long-term Borrowings + Short-term Borrowings) / EBITDA"
    },
    "Interest Coverage": {
      "synonyms": ["DSCR", "Debt Service Coverage Ratio", "Times Interest Earned", "ICR"],
      "formula": "Operating Profit / Finance Costs"
    },
    "Return on Equity": {
      "synonyms": ["ROE"],
      "formula": "Profit for the Year / Total Equity"
    },
    "Return on Assets": {
      "synonyms": ["ROA"],
      "formula": "Profit for the Year / Total Assets"
    },
    "Net Profit Margin": {
      "synonyms": ["Net Margin", "Profit Margin"],
      "formula": "Profit for the Year / Revenue"
    },
    "Gross Profit Margin": {
      "synonyms": ["Gross Margin %"],
      "formula": "Gross Profit / Revenue"
    },
    "Operating Profit Margin": {
      "synonyms": ["Operating Margin", "EBIT Margin"],
      "formula": "Operating Profit / Revenue"
    },
    "Asset Turnover": {
      "synonyms": ["Total Asset Turnover"],
      "formula": "Revenue / Total Assets"
    },
    "Inventory Days": {
      "synonyms": ["Days Inventory Outstanding", "DIO", "Stock Days"],
      "formula": "(Inventories / Cost of Sales) × 365"
    },
    "Receivable Days": {
      "synonyms": ["Days Sales Outstanding", "DSO", "Debtor Days", "Collection Period"],
      "formula": "(Trade Receivables / Revenue) × 365"
    },
    "Payable Days": {
      "synonyms": ["Days Payable Outstanding", "DPO", "Creditor Days", "Payment Period"],
      "formula": "(Trade Payables / Cost of Sales) × 365"
    },
    "Cash Conversion Cycle": {
      "synonyms": ["CCC", "Cash Cycle"],
      "formula": "Inventory Days + Receivable Days - Payable Days"
    },
    "Working Capital": {
      "synonyms": ["Net Working Capital", "NWC"],
      "formula": "Total Current Assets - Total Current Liabilities"
    },
    "EBITDA Margin": {
      "synonyms": ["EBITDA %"],
      "formula": "EBITDA / Revenue"
    },
    "Equity Ratio": {
      "synonyms": ["Equity to Assets"],
      "formula": "Total Equity / Total Assets"
    },
    "Net Debt": {
      "synonyms": ["Net Borrowings"],
      "formula": "(Long-term Borrowings + Short-term Borrowings) - Cash and Cash Equivalents"
    },
    "Free Cash Flow": {
      "synonyms": ["FCF"],
      "formula": "Cash from Operating Activities - Purchase of PPE"
    }
  }
}
